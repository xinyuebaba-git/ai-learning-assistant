# 应用配置
APP_NAME=Course AI Helper
DEBUG=true

# 数据库配置
# SQLite (开发环境)
DATABASE_URL=sqlite+aiosqlite:///./data/course_ai.db

# PostgreSQL (生产环境)
# DATABASE_URL=postgresql+psycopg2://user:password@localhost:5432/course_ai

# JWT 认证（生产环境务必修改）
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 数据存储目录
DATA_DIR=./data
VIDEO_DIR=./data/videos
SUBTITLE_DIR=./data/subtitles
SUMMARY_DIR=./data/summaries
EMBEDDING_DIR=./data/embeddings
CHROMA_PERSIST_DIR=./data/chroma

# 向量嵌入模型
EMBEDDING_MODEL=bge-small-zh-v1.5

# LLM 配置 - 本地 Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# LLM 配置 - DeepSeek
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_API_KEY=your-deepseek-api-key

# LLM 配置 - OpenAI
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-mini
OPENAI_API_KEY=your-openai-api-key

# 默认 LLM 后端：local / deepseek / openai
DEFAULT_LLM_BACKEND=local

# ASR 配置
ASR_ENGINE=faster-whisper
ASR_MODEL=medium

# 字幕分段配置
MAX_SEGMENT_DURATION=2.2
MAX_SEGMENT_CHARS=28

# 搜索配置
SEARCH_TOP_K=10
SEARCH_SCORE_THRESHOLD=0.5
